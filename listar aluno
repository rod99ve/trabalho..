<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Alunos</title>
</head>
<body>

<h2>Cadastro de Alunos</h2>

<form method="post">
    Matrícula:<br>
    <input type="text" name="matricula"><br><br>

    Nome:<br>
    <input type="text" name="nome"><br><br>

    Email:<br>
    <input type="text" name="email"><br><br>

    <input type="submit" name="incluir" value="Incluir">
    <input type="submit" name="alterar" value="Alterar">
</form>

<hr>

<?php
$arquivo = "alunos.txt";
$mensagem = "";

/* ========= INCLUIR ========= */
if (isset($_POST["incluir"])) {

    $matricula = $_POST["matricula"];
    $nome = $_POST["nome"];
    $email = $_POST["email"];

    if ($matricula == "" || $nome == "" || $email == "") {
        $mensagem = "Campos obrigatórios.";
    } else {
        $linha = $matricula . ";" . $nome . ";" . $email . "\n";
        file_put_contents($arquivo, $linha, FILE_APPEND);
        $mensagem = "Aluno incluído.";
    }
}

/* ========= ALTERAR ========= */
if (isset($_POST["alterar"])) {

    $matricula = $_POST["matricula"];
    $nome = $_POST["nome"];
    $email = $_POST["email"];

    if ($matricula == "" || $nome == "" || $email == "") {
        $mensagem = "Campos obrigatórios.";
    } else if (file_exists($arquivo)) {

        $linhas = file($arquivo);
        $novoConteudo = "";
        $achou = false;

        foreach ($linhas as $linha) {
            $dados = explode(";", $linha);

            if ($dados[0] == $matricula) {
                $novoConteudo .= $matricula . ";" . $nome . ";" . $email . "\n";
                $achou = true;
            } else {
                $novoConteudo .= $linha;
            }
        }

        if ($achou) {
            file_put_contents($arquivo, $novoConteudo);
            $mensagem = "Aluno alterado.";
        } else {
            $mensagem = "Matrícula não encontrada.";
        }
    }
}

echo "<p>$mensagem</p>";

/* ========= LISTAR ========= */
echo "<h3>Lista de Alunos</h3>";

if (file_exists($arquivo)) {

    $fp = fopen($arquivo, "r");

    while (!feof($fp)) {
        $linha = fgets($fp);

        if ($linha != "") {
            $dados = explode(";", $linha);

            echo "Matrícula: " . $dados[0] . "<br>";
            echo "Nome: " . $dados[1] . "<br>";
            echo "Email: " . $dados[2] . "<br>";
            echo "<hr>";
        }
    }

    fclose($fp);
} else {
    echo "Nenhum aluno cadastrado.";
}
?>

</body>
</html>
