<?php
    $a = 0;
    $resultado = "";

    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        $a = $_POST["a"];

        if ($a >= 0) {
            $resultado = sqrt($a);
        } else {
            $resultado = "Não existe raiz real";
        }
    }
?>

