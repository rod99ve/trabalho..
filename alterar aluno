<!DOCTYPE html>
<html>
<head>
    <title>Alunos</title>
</head>
<body>

<?php
$arquivo = "alunos.txt";
$mensagem = "";

if (isset($_POST["incluir"])) {

    $matricula = $_POST["matricula"];
    $nome = $_POST["nome"];
    $email = $_POST["email"];

    if ($matricula == "" || $nome == "" || $email == "") {
        $mensagem = "Campos obrigatórios.";
    } else {
        $linha = $matricula . ";" . $nome . ";" . $email . "\n";
        file_put_contents($arquivo, $linha, FILE_APPEND);
        $mensagem = "Aluno incluído.";
    }
}

if (isset($_POST["alterar"])) {

    $matricula = $_POST["matricula"];
    $nome = $_POST["nome"];
    $email = $_POST["email"];

    if ($matricula == "" || $nome == "" || $email == "") {
        $mensagem = "Campos obrigatórios.";
    } else if (file_exists($arquivo)) {

        $linhas = file($arquivo);
        $novoConteudo = "";
        $achou = false;

        foreach ($linhas as $linha) {
            $dados = explode(";", $linha);

            if ($dados[0] == $matricula) {
                $novoConteudo .= $matricula . ";" . $nome . ";" . $email . "\n";
                $achou = true;
            } else {
                $novoConteudo .= $linha;
            }
        }

        if ($achou) {
            file_put_contents($arquivo, $novoConteudo);
            $mensagem = "Aluno alterado.";
        } else {
            $mensagem = "Matrícula não encontrada.";
        }
    }
}

echo $mensagem;
?>

</body>
</html>
