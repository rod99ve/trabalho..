<?php
session_start();

$agendamentos_file = 'agendamentos.json';
$clientes_file     = 'clientes.json';

function lerJSON($f){ return file_exists($f) ? json_decode(file_get_contents($f),true)??[] : []; }
function salvarJSON($f,$d){ file_put_contents($f,json_encode($d,JSON_PRETTY_PRINT|JSON_UNESCAPED_UNICODE)); }
function initJSON($f){ if(!file_exists($f)) file_put_contents($f,'[]'); }

initJSON($agendamentos_file);
initJSON($clientes_file);

$action = $_REQUEST['action'] ?? '';

if($action==='login'){
    $clientes=lerJSON($clientes_file);
    $ok=false;
    foreach($clientes as $c){
        if($c['email']===$_POST['email'] && $c['senha']===md5($_POST['senha'])){
            $_SESSION['cliente']=$c; $ok=true; break;
        }
    }
    header('Content-Type: application/json');
    echo json_encode(['sucesso'=>$ok,'mensagem'=>$ok?'OK':'Email ou senha inválidos.']);
    exit;
}

if($action==='criar_conta'){
    $n=$_POST['nome']??''; $e=$_POST['email']??''; $s=$_POST['senha']??'';
    if(!$n||!$e||!$s){ header('Content-Type: application/json'); echo json_encode(['sucesso'=>false,'mensagem'=>'Preencha tudo.']); exit; }
    $clientes=lerJSON($clientes_file);
    foreach($clientes as $c){ if($c['email']===$e){ header('Content-Type: application/json'); echo json_encode(['sucesso'=>false,'mensagem'=>'Email já cadastrado.']); exit; } }
    $novo=['id'=>uniqid(),'nome'=>$n,'email'=>$e,'senha'=>md5($s)];
    $clientes[]=$novo; salvarJSON($clientes_file,$clientes);
    $_SESSION['cliente']=$novo;
    header('Content-Type: application/json'); echo json_encode(['sucesso'=>true,'mensagem'=>'Conta criada!']); exit;
}

if($action==='logout'){ session_destroy(); header('Location: index.php'); exit; }

if($action==='agendar'){
    $ag=['id'=>uniqid('A'),'nome'=>$_POST['nome']??($_SESSION['cliente']['nome']??''),'email'=>$_POST['email']??($_SESSION['cliente']['email']??''),'servico'=>$_POST['servico']??'','data'=>$_POST['data']??'','hora'=>$_POST['hora']??'','status'=>'Pendente','criado'=>date('Y-m-d H:i:s')];
    $lista=lerJSON($agendamentos_file); $lista[]=$ag; salvarJSON($agendamentos_file,$lista);
    $_SESSION['agendamento']=$ag;
    header('Content-Type: application/json'); echo json_encode(['sucesso'=>true,'agendamento'=>$ag]); exit;
}

if($action==='pagar'){
    $lista=lerJSON($agendamentos_file);
    foreach($lista as &$a){ if($a['id']===$_POST['id']){ $a['status']='Pago'; $a['metodo']=$_POST['metodo']??''; } }
    salvarJSON($agendamentos_file,$lista);
    header('Content-Type: application/json'); echo json_encode(['sucesso'=>true]); exit;
}

if($action==='agendamentos'){ header('Content-Type: application/json'); echo json_encode(lerJSON($agendamentos_file)); exit; }

$cli = $_SESSION['cliente'] ?? null;
?>
