
<!DOCTYPE html>
<html>
<body>

<h2>Cadastrar Usuário</h2>
<form method="post">
Nome: <input type="text" name="nome" required><br><br>
Email: <input type="email" name="email" required><br><br>
Senha: <input type="password" name="senha" required><br><br>
<input type="submit" name="cadastrar_usuario" value="Cadastrar Usuário">
</form>

<?php
$arquivoUsuarios = "usuarios.txt";

if (isset($_POST["cadastrar_usuario"])) {
    $nome = $_POST["nome"]; $email = $_POST["email"]; $senha = $_POST["senha"];
    file_put_contents($arquivoUsuarios, "$nome;$email;$senha\n", FILE_APPEND);
}

if (file_exists($arquivoUsuarios)) {
    $linhas = file($arquivoUsuarios);
    foreach ($linhas as $i => $linha) {
        $d = explode(";", $linha);
        echo "Nome: $d[0] | Email: $d[1] ";
        echo "<a href='?excluir_usuario=$i'>Excluir</a><br>";
    }
}

if (isset($_GET["excluir_usuario"])) {
    $linhas = file($arquivoUsuarios);
    unset($linhas[$_GET["excluir_usuario"]]);
    file_put_contents($arquivoUsuarios, $linhas);
    header("Location: sistema.php");
}
?>

