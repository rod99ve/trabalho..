    $pergunta = $_POST["pergunta"]; $a = $_POST["a"]; $b = $_POST["b"];
    $c = $_POST["c"]; $d = $_POST["d"]; $correta = $_POST["correta"];
    file_put_contents($arquivoPerguntas, "$pergunta;$a;$b;$c;$d;$correta\n", FILE_APPEND);
}

if (file_exists($arquivoPerguntas)) {
