if (isset($_POST["cadastrar_pergunta"])) {
    $dados = $_POST["pergunta"].";".$_POST["a"].";".$_POST["b"].";".$_POST["c"].";".$_POST["d"].";".$_POST["correta"]."\n";
    file_put_contents($arquivoMultipla, $dados, FILE_APPEND);
