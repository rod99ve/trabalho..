?>

<script>
function enviarFormulario(event, form) {
    event.preventDefault();
    
    var dados = new FormData(form);
    var xhr = new XMLHttpRequest();
    
    xhr.open("POST", "sistema.php", true);
    xhr.onload = function() {
        if (xhr.responseText.trim() === "sucesso") {
            location.reload();
        }
    };
    xhr.send(dados);
}

function excluirItem(tipoAcao, id) {
    if (confirm("Tem certeza que deseja excluir?")) {
        var xhr = new XMLHttpRequest();
        xhr.open("GET", "sistema.php?" + tipoAcao + "=" + id, true); 
        xhr.onload = function() {
            if (xhr.responseText.trim() === "sucesso") {
                location.reload();
            }
        };
        xhr.send();
    }
}
</script>

