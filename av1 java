}

if (isset($_GET["excluir_multipla"])) {
    $id = $_GET["excluir_multipla"];
    $linhas = file($arquivoMultipla);
    unset($linhas[$id]);
    file_put_contents($arquivoMultipla, $linhas);
    echo "sucesso";
    exit;
}

if (isset($_GET["excluir_texto"])) {
