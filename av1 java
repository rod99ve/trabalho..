    exit;
}

if (isset($_POST["cadastrar_texto"])) {
    $dados = $_POST["pergunta_texto"].";".$_POST["resposta_texto"]."\n";
    file_put_contents($arquivoTexto, $dados, FILE_APPEND);
    echo "sucesso";
    exit;
}

if (isset($_GET["excluir_usuario"])) {
    $id = $_GET["excluir_usuario"];
    $linhas = file($arquivoUsuarios);
    unset($linhas[$id]);
    file_put_contents($arquivoUsuarios, $linhas);
    echo "sucesso";
